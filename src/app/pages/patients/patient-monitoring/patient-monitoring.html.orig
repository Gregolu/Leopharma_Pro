<div class="patient-monitoring-container">

  <!-- Header Section -->
  <div class="monitoring-header">
    <div class="header-titles">
      <h2>Monitoring du patient</h2>
    </div>
    <div class="header-actions">
      <div class="alert-toggle-wrapper">
        <span class="alert-label">Alerte</span>
        <div class="toggle-switch" (click)="toggleGlobalAlert()" [class.active]="globalAlertOn">
          <span class="state-text">{{ globalAlertOn ? 'Actif' : 'Inactif' }}</span>
          <div class="switch-knob"></div>
        </div>
      </div>
      <button class="btn-download">
        <i class="fas fa-file-download"></i>
        Télécharger le dossier patient
      </button>
      <button class="btn-add-widget" style="width: 40px; height: 40px; border-radius: 50%; background-color: #f7f9fc; border: 1px solid #d4d4d8; cursor: pointer; display: flex; align-items: center; justify-content: center; color: #1e3a29;">
        <i class="fas fa-plus"></i>
      </button>
    </div>
  </div>

  <!-- SECTION: ALERTE ACTIVÉE -->
  <div class="accordion-section">
    <div class="accordion-header active-alert-bg" (click)="toggleSection('active')">
      <div class="header-left">
        <div class="icon-bell active-bell"><i class="fas fa-bell"></i></div>
        <h3>Alerte activée</h3>
      </div>
      <div class="header-right">
        <button class="icon-btn" title="Paramètres" (click)="$event.stopPropagation()">
            <i class="fas fa-cog"></i>
        </button>
        <i class="fas fa-chevron-down toggle-arrow" [class.rotated]="!sections.active"></i>
      </div>
    </div>
    
    <div class="accordion-content" *ngIf="sections.active">
        <div class="charts-grid">
            
            <!-- Graphe 1: IGA-CHE -->
            <div class="chart-wrapper">
                <div class="chart-block">
                    <div class="c-header">
                        <div class="header-left-title">
                            <i class="fas" [class.fa-bell]="alertIGA()" [class.fa-bell-slash]="!alertIGA()" [class.active-icon-color]="alertIGA()" [class.inactive-icon-color]="!alertIGA()" (click)="toggleAlert('iga')" style="cursor: pointer;"></i>
                            <h3>Evolution des symptômes (IGA-CHE)</h3>
                        </div>
                        <div class="actions-right">
                            <div class="c-badge" style="color: #1e3a29;">1</div>
                            <button class="settings-btn" title="Paramètres" (click)="openAlertModal('iga')"><i class="fas fa-cog"></i></button>
                        </div>
                    </div>
                    <div class="c-graph-layout">
                        <div class="y-axis">
                            <span>4</span>
                            <span>2</span>
                            <span>0</span>
                        </div>
                        <div class="c-graph-main">
                        <div class="c-wrap">
                            <svg viewBox="0 0 300 100" class="c-svg" preserveAspectRatio="none">                                                                                               
                                <!-- Graph line -->
                                <polyline points="40,40 80,47 120,80 160,86" fill="none" stroke="#1e293b" stroke-width="1.5"/>                                                                  
                                <circle cx="40" cy="40" r="4" fill="#ff5a5f"/>
                                <circle cx="80" cy="47" r="4" fill="#ff5a5f"/>
                                <circle cx="120" cy="80" r="4" fill="#1e3a29"/>
                                <circle cx="160" cy="86" r="4" fill="#1e3a29"/>
                            </svg>
                            <!-- Moyenne ligne -->
                            <div class="mean-line-container" style="top: 50%;">
                                <div class="mean-line"></div>
                                <span class="mean-label">— Moy.</span>
                            </div>
                        </div>
                        <div class="x-axis">
                            <span>01.02.25</span>
                            <span>30.02.25</span>
                        </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Graphe 3: Suivi des traitements -->
            <div class="chart-wrapper">
                <div class="chart-block">
                <div class="c-header">                                                        
                    <div class="header-left-title">
                        <i class="fas" [class.fa-bell]="alertTreatment()" [class.fa-bell-slash]="!alertTreatment()" [class.active-icon-color]="alertTreatment()" [class.inactive-icon-color]="!alertTreatment()" (click)="toggleAlert('treatment')" style="cursor: pointer;"></i>
                        <h3>Suivi des traitements</h3>
                    </div>
                    <div class="actions-right">
                        <button class="settings-btn" title="Paramètres" (click)="openAlertModal('treatment')"><i class="fas fa-cog"></i></button>
                    </div>
                </div>
                <!-- Legendary moved right below header -->
                <div class="chart-legend" style="display: flex; gap: 16px; font-size: 13px; font-weight: 600; color: #1e293b; padding: 0 16px 12px 16px;">                           
                    <div style="display: flex; align-items: center; gap: 6px;">                                                                             
                        <div style="width: 12px; height: 12px; border-radius: 50%; background: #71c671;"></div> Crèmes hydratantes                            
                    </div>
                    <div style="display: flex; align-items: center; gap: 6px;">
                        <div style="width: 12px; height: 12px; border-radius: 50%; background: #eab365;"></div> Hydrocortisone                                                        
                    </div>
                </div>
                <div class="c-graph-layout">
                    <div class="y-axis">
                    <span>10</span>
                    <span>5</span>
                    <span>0</span>
                    </div>
                    <div class="c-graph-main">
                        <div class="c-wrap">
                        <svg viewBox="0 0 300 100" class="c-svg" preserveAspectRatio="none">                                                                                               
                            <!-- Bar 1 -->
                            <rect x="40" y="20" width="12" height="40" fill="#71c671" rx="6" />                                                                                             
                            <rect x="40" y="55" width="12" height="35" fill="#eab365" rx="6" />                                                                                             
                            <!-- Shadows below bars -->
                            <ellipse cx="46" cy="95" rx="8" ry="2" fill="#e2e8f0"/>

                            <!-- Bar 2 -->
                            <rect x="70" y="45" width="12" height="30" fill="#71c671" rx="6" />                                                                                             
                            <rect x="70" y="65" width="12" height="25" fill="#eab365" rx="6" />                                                                                             
                            <ellipse cx="76" cy="95" rx="8" ry="2" fill="#e2e8f0"/>

                            <!-- Bar 3 -->
                            <rect x="90" y="40" width="12" height="20" fill="#71c671" rx="6" />                                                                                             
                            <rect x="90" y="52" width="12" height="38" fill="#eab365" rx="6" />                                                                                             
                            <ellipse cx="96" cy="95" rx="8" ry="2" fill="#e2e8f0"/>

                            <!-- Bar 4 -->
                            <rect x="130" y="65" width="12" height="20" fill="#71c671" rx="6" />                                                                                            
                            <rect x="130" y="80" width="12" height="10" fill="#eab365" rx="6" />                                                                                            
                            <ellipse cx="136" cy="95" rx="8" ry="2" fill="#e2e8f0"/>                                                                                                     
                        </svg>
                        <!-- Moyenne ligne rose -->
                        <div class="mean-line-container" style="top: 50%;">
                            <div class="mean-line pink"></div>
                        </div>
                        </div>
                    </div>
                </div>
                </div>
            </div>
            
        </div>
    </div>
  </div>

  <!-- SECTION: ALERTE DÉSACTIVÉE -->
  <div class="accordion-section">
    <div class="accordion-header inactive-alert-bg" (click)="toggleSection('inactive')">
      <div class="header-left">
        <div class="icon-bell inactive-bell"><i class="fas fa-bell-slash"></i></div>
        <h3>Alerte désactivée</h3>
      </div>
      <div class="header-right">
        <button class="icon-btn" title="Paramètres" (click)="$event.stopPropagation()">
            <i class="fas fa-cog"></i>
        </button>
        <i class="fas fa-chevron-down toggle-arrow" [class.rotated]="!sections.inactive"></i>
      </div>
    </div>
    
    <div class="accordion-content" *ngIf="sections.inactive">
        <div class="charts-grid">
            
            <!-- Graphe 2: Qualité de vie -->
            <div class="chart-wrapper">
                <div class="chart-block disabled-look">
                    <div class="c-header">
                        <div class="header-left-title">
                            <i class="fas" [class.fa-bell]="alertBoHG()" [class.fa-bell-slash]="!alertBoHG()" [class.active-icon-color]="alertBoHG()" [class.inactive-icon-color]="!alertBoHG()" (click)="toggleAlert('bohg')" style="cursor: pointer;"></i>
                            <h3>Evolution de la qualité de vie (BoHG)</h3>
                        </div>
                        <div class="actions-right">
                            <div class="c-badge" style="color: #1e3a29;">14</div>
                            <button class="settings-btn" title="Paramètres" (click)="openAlertModal('bohg')"><i class="fas fa-cog"></i></button>
                        </div>
                    </div>
                    <div class="c-graph-layout">
                        <div class="y-axis">
                            <span>48</span>
                            <span>24</span>
                            <span>0</span>
                        </div>
                        <div class="c-graph-main">
                            <div class="c-wrap">
                            <svg viewBox="0 0 300 100" class="c-svg" preserveAspectRatio="none">                                                                                               
                                <!-- Graph line -->
                                <polyline points="40,35 80,42 120,82 160,85" fill="none" stroke="#1e293b" stroke-width="1.5"/>                                     
                                <circle cx="40" cy="35" r="4" fill="#ff5a5f"/>
                                <circle cx="80" cy="42" r="4" fill="#ff5a5f"/>
                                <circle cx="120" cy="82" r="4" fill="#1e3a29"/>
                                <circle cx="160" cy="85" r="4" fill="#1e3a29"/>
                            </svg>
                            <!-- Moyenne ligne -->
                            <div class="mean-line-container" style="top: 50%;">
                                <div class="mean-line"></div>
                                <span class="mean-label">— Moy.</span>
                            </div>
                            </div>
                            <div class="x-axis">
                                <span>01.02.25</span>
                                <span>30.02.25</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
  </div>

  <!-- Modal pour gérer l'alerte du graphe -->
  <div class="modal-overlay" *ngIf="isModalOpen()" (click)="closeModal()">
    <div class="modal-content" (click)="$event.stopPropagation()">
      <div class="modal-header">
        <h3>Paramètres d'alerte : {{ selectedGraphForAlert() | uppercase }}</h3>
        <button class="close-btn" (click)="closeModal()"><i class="fas fa-times"></i></button>
      </div>
      <div class="modal-body">
        <div class="form-group">
          <label>Niveau de l'alerte (seuil)</label>
          <input type="number" [(ngModel)]="alertThreshold" min="2" max="4" style="width: 100%; border: 1px solid #cbd5e1; border-radius: 8px; padding: 12px; font-size: 0.95rem;">
          <small style="color: #64748b;">Valeur recommandée entre 2 et 4</small>
        </div>

        <div class="form-group" style="margin-top: 16px;">
          <label>Récurrences associées</label>
          <input type="number" [(ngModel)]="alertRecurrences" min="1" max="10" style="width: 100%; border: 1px solid #cbd5e1; border-radius: 8px; padding: 12px; font-size: 0.95rem;">
        </div>

        <div class="form-group" style="margin-top: 16px;">
          <label>En lien avec un autre graphe</label>
          <select [(ngModel)]="alertLinkedGraph" style="width: 100%; border: 1px solid #cbd5e1; border-radius: 8px; padding: 12px; font-size: 0.95rem; background: white;">
            <option value="">Aucun lien</option>
            <option value="iga">IGA-CHE</option>
            <option value="bohg">BoHG</option>
            <option value="treatment">Suivi des traitements</option>
          </select>
        </div>
      </div>
      <div class="modal-footer" style="padding-top: 24px; border-top: 1px solid #e2e8f0; display: flex; justify-content: flex-end; gap: 12px;">
        <button class="btn-cancel" style="background: white; border: 1px solid #cbd5e1; padding: 10px 20px; border-radius: 8px; cursor: pointer; color: #475569;" (click)="closeModal()">Annuler</button>
        <button class="btn-delete" style="background: #ef4444; border: none; padding: 10px 20px; border-radius: 8px; cursor: pointer; color: white;" (click)="deleteAlert()">Supprimer l'alerte</button>
        <button class="btn-save" style="background: #204131; border: none; padding: 10px 20px; border-radius: 8px; cursor: pointer; color: white;" (click)="saveAlert()">Valider</button>
      </div>
    </div>
  </div>

</div>
